{
  "name": "mcp-server-e-conomic",
  "version": "0.1.1",
  "description": "Policy-aware MCP server for Visma e-conomic APIs.",
  "type": "module",
  "main": "./dist/stdio.js",
  "bin": {
    "mcp-server-e-conomic": "./dist/stdio.js"
  },
  "scripts": {
    "build": "tsup src/transports/stdio.ts src/transports/http.ts --format esm --dts --clean --sourcemap",
    "dev": "tsx src/transports/stdio.ts",
    "dev:http": "tsx src/transports/http.ts",
    "auth:grant": "tsx src/auth/capture-grant-token.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke:live": "tsx test/live-smoke.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Borgels/mcp-server-e-conomic.git"
  },
  "keywords": [
    "mcp",
    "e-conomic",
    "economic",
    "visma",
    "accounting"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.11"
  },
  "bugs": {
    "url": "https://github.com/Borgels/mcp-server-e-conomic/issues"
  },
  "homepage": "https://github.com/Borgels/mcp-server-e-conomic#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
